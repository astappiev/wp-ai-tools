{
	"name": "wp-ai-tools",
	"version": "0.0.1",
	"license": "proprietary",
	"private": true,
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"format": "wp-scripts format",
		"translate": "pnpm run translate:pot && pnpm run translate:update",
		"translate:pot": "wp i18n make-pot . languages/wp-ai-tools.pot --exclude=src",
		"translate:update": "wp i18n update-po languages/wp-ai-tools.pot",
		"translate:compile": "pnpm run translate:mo && pnpm run translate:js",
		"translate:js": "wp i18n make-json languages --no-purge",
		"translate:mo": "wp i18n make-mo languages",
		"lint": "pnpm run lint:css && pnpm run lint:js",
		"lint:css": "wp-scripts lint-style ./src/**/*.scss",
		"lint:js": "wp-scripts lint-js ./src"
	},
	"dependencies": {
		"react-router-dom": "^7.18.1"
	},
	"devDependencies": {
		"@types/react": "^18.3.31",
		"@types/react-dom": "^18.3.7",
		"@wordpress/icons": "^15.1.0",
		"@wordpress/scripts": "^32.6.0"
	}
}
